projects/*/*/*.jsonl
projects/*/subagents/
projects/*/tool-results/
projects/*/*/subagents/
projects/*/*/tool-results/

# Sync log (machine-specific)
sync.log

# macOS
.DS_Store
**/.DS_Store

# Plans (session-specific)
plans/

# Tasks (session-specific)
tasks/
